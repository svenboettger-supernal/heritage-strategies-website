---
import "@styles/global.css";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import CookieBanner from "@components/CookieBanner.astro";
import Head from "@components/Head.astro";

export interface Props {
  title: string;
  description: string;
  /** Path of the current page relative to the site base, used for canonical + breadcrumbs. e.g. "/about/" */
  pathname?: string;
  /** Disable the header on landing surfaces if needed. Defaults to true. */
  showHeader?: boolean;
  /** Disable the footer on stub pages. Defaults to true. */
  showFooter?: boolean;
  /** When true, the body root carries `on-dark` for inverted text on hero-only pages. Rare. */
  invertChrome?: boolean;
  /** OG image relative to /public. Defaults to og-image.svg */
  ogImage?: string;
  /** Inject extra JSON-LD schemas (BreadcrumbList, Person, etc.) per-page. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  pathname = "/",
  showHeader = true,
  showFooter = true,
  invertChrome = false,
  ogImage,
  jsonLd,
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <Head
    title={title}
    description={description}
    pathname={pathname}
    ogImage={ogImage}
    jsonLd={jsonLd}
  />
  <body class={invertChrome ? "on-dark bg-surface-dark text-ink-on-dark" : "bg-surface-page text-ink"}>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-3 focus:left-3 focus:z-50 focus:bg-surface-card focus:px-3 focus:py-2 focus:text-ink focus:rounded"
    >
      Skip to content
    </a>

    {showHeader && <Header pathname={pathname} />}

    <main id="main" class="min-h-[60vh]">
      <slot />
    </main>

    {showFooter && <Footer />}
    <CookieBanner />
  </body>
</html>
