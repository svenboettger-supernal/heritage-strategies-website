---
export interface Props {
  /** Orientation of the lockup. */
  orientation?: "horizontal" | "vertical" | "mark-only";
  /** Use light treatment for dark surfaces (text becomes ink-on-dark). */
  onDark?: boolean;
  /** Seal pixel size; the wordmark scales relative to it. */
  size?: number;
  class?: string;
  /** Render as a link to home. */
  href?: string;
  ariaLabel?: string;
}

const {
  orientation = "horizontal",
  onDark = false,
  size = 56,
  class: className = "",
  href,
  ariaLabel = "Heritage Strategies LLC",
} = Astro.props;

const Tag = href ? "a" : "div";

const wordmarkColor = onDark
  ? "text-ink-on-dark"
  : "text-ink";
---

<Tag
  href={href}
  aria-label={ariaLabel}
  class:list={[
    "inline-flex items-center group",
    orientation === "vertical" && "flex-col gap-2",
    orientation === "horizontal" && "flex-row gap-3 md:gap-4",
    orientation === "mark-only" && "",
    className,
  ]}
>
  {/* Wax-seal mark — SVG re-creation of the HS monogram */}
  <svg
    width={size}
    height={size}
    viewBox="0 0 80 80"
    role="img"
    aria-label="Heritage Strategies wax seal"
    class="shrink-0 transition-transform duration-fast group-hover:rotate-[-2deg]"
  >
    <defs>
      <radialGradient id="waxBody" cx="40%" cy="35%" r="65%">
        <stop offset="0%" stop-color="hsl(22 65% 58%)" />
        <stop offset="55%" stop-color="hsl(20 55% 48%)" />
        <stop offset="100%" stop-color="hsl(15 50% 30%)" />
      </radialGradient>
      <radialGradient id="waxHighlight" cx="38%" cy="32%" r="22%">
        <stop offset="0%" stop-color="hsl(28 75% 78% / 0.85)" />
        <stop offset="100%" stop-color="hsl(28 75% 78% / 0)" />
      </radialGradient>
    </defs>

    {/* Outer wax body — slightly irregular circle */}
    <path
      d="M40 4
         C 56 4 70 14 74 28
         C 78 41 74 56 64 66
         C 54 76 38 78 26 72
         C 13 65 4 51 6 36
         C 8 21 22 6 40 4 Z"
      fill="url(#waxBody)"
      stroke="hsl(15 55% 22%)"
      stroke-width="1"
    />
    {/* Highlight */}
    <ellipse cx="32" cy="28" rx="14" ry="10" fill="url(#waxHighlight)" />

    {/* HS monogram, classical caps */}
    <g fill="hsl(15 60% 18%)" font-family='"Cormorant Garamond", "Cormorant", serif' font-weight="600">
      <text x="22" y="50" font-size="22" letter-spacing="-1">H</text>
      <text x="40" y="56" font-size="22" letter-spacing="-1">S</text>
    </g>
    {/* Hairline under monogram, the signature thin streak */}
    <line
      x1="20" y1="58" x2="60" y2="58"
      stroke="hsl(15 60% 18%)" stroke-width="0.6" stroke-linecap="round"
      opacity="0.55"
    />
  </svg>

  {orientation !== "mark-only" && (
    <span
      class:list={[
        "font-display font-medium leading-[1.05] tracking-[0.04em]",
        orientation === "vertical" ? "text-center" : "",
        wordmarkColor,
      ]}
      style={`font-size: ${Math.round(size * 0.30)}px;`}
    >
      <span class="block uppercase">Heritage</span>
      <span class:list={["block uppercase", "text-[0.82em] opacity-90"]}>Strategies <span class="tracking-[0.08em] text-[0.78em] align-baseline">LLC</span></span>
    </span>
  )}
</Tag>
