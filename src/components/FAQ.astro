---
export interface Props {
  items: Array<{ question: string; answer: string }>;
  /** Inject JSON-LD FAQPage schema. */
  schema?: boolean;
  class?: string;
}

const { items, schema = true, class: className = "" } = Astro.props;

const faqSchema = schema
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: items.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    }
  : null;
---

<div class:list={["divide-y divide-[hsl(var(--border-default))] border-y border-default", className]}>
  {items.map((item, idx) => (
    <details class="group" name="hs-faq" open={idx === 0}>
      <summary class="flex items-start justify-between gap-6 py-5 cursor-pointer list-none">
        <span class="font-display text-[1.25rem] md:text-[1.4rem] leading-snug text-ink text-balance">
          {item.question}
        </span>
        <span aria-hidden="true" class="shrink-0 mt-1.5 text-ink-muted group-open:rotate-45 transition-transform duration-fast">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
            <line x1="9" y1="3" x2="9" y2="15" />
            <line x1="3" y1="9" x2="15" y2="9" />
          </svg>
        </span>
      </summary>
      <div class="pb-6 pr-10 max-w-screen-prose">
        <p class="prose-editorial text-ink text-[1.05rem] leading-relaxed">{item.answer}</p>
      </div>
    </details>
  ))}
</div>

{faqSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
)}
