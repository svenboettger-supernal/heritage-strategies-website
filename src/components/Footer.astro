---
import Logo from "@components/Logo.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const year = new Date().getFullYear();

const cols = [
  {
    title: "Firm",
    links: [
      { label: "About", href: `${base}/about/` },
      { label: "Services", href: `${base}/services/` },
      { label: "Press", href: `${base}/press/` },
      { label: "Resources", href: `${base}/resources/` },
      { label: "Careers", href: `${base}/careers/` },
    ],
  },
  {
    title: "Practice",
    links: [
      { label: "The Heritage Book", href: `${base}/services/methodology/` },
      { label: "Estate & Business Continuity", href: `${base}/services/estate-planning/` },
      { label: "Heritage Benefit Solutions", href: `${base}/services/heritage-benefit-solutions/` },
      { label: "Community Impact", href: `${base}/about/#community-impact` },
    ],
  },
  {
    title: "Office",
    body: [
      "135 Crossways Park Dr #402",
      "Woodbury, NY 11797",
    ],
    links: [
      { label: "212.485.1536", href: "tel:+12124851536" },
      { label: "info@heritagesllc.com", href: "mailto:info@heritagesllc.com" },
      { label: "Contact us", href: `${base}/contact/` },
    ],
  },
];
---

<footer class="bg-surface-dark text-ink-on-dark on-dark">
  <div class="mx-auto max-w-screen-wide px-6 sm:px-8 lg:px-12 py-16 md:py-20">
    <div class="grid gap-12 md:gap-16 md:grid-cols-[1.4fr_repeat(3,1fr)]">
      <div>
        <Logo size="footer" onDark ariaLabel="Heritage Strategies LLC" />
        <p class="mt-6 max-w-xs text-sm leading-relaxed text-ink-muted-on-dark">
          An estate-planning multi-family office serving ultra-high-net-worth families and their advisors since 2009.
        </p>
      </div>

      {cols.map((col) => (
        <div>
          <p class="eyebrow text-ink-muted-on-dark mb-4">{col.title}</p>
          {col.body && (
            <address class="not-italic text-sm leading-relaxed text-ink-muted-on-dark mb-3">
              {col.body.map((line) => <span class="block">{line}</span>)}
            </address>
          )}
          <ul class="space-y-2.5">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="no-underline text-sm text-ink-on-dark hover:underline underline-offset-4 decoration-1"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <div class="border-t border-rule-dark">
    <div class="mx-auto max-w-screen-wide px-6 sm:px-8 lg:px-12 py-8">
      <p class="text-[12.5px] leading-relaxed text-ink-muted-on-dark max-w-screen-prose">
        Securities and Investment Advisory Services offered through M Holdings Securities, Inc., a Registered Broker/Dealer and Investment Advisor, Member FINRA/SIPC. Heritage Strategies LLC is independently owned and operated. Heritage Strategies LLC is a Member of M Financial Group.
      </p>
      <p class="mt-3 text-[12.5px] leading-relaxed text-ink-muted-on-dark max-w-screen-prose">
        Registered Representatives are registered to conduct securities business and licensed to conduct insurance business in limited states. This site is for information purposes and should not be construed as legal or tax advice and is not intended to replace the advice of a qualified attorney, financial or tax advisor or plan provider.
      </p>

      <div class="mt-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <p class="text-[12px] text-ink-muted-on-dark">
          © {year} Heritage Strategies LLC. All rights reserved. Tracking #3985052.2
        </p>
        <ul class="flex flex-wrap items-center gap-x-5 gap-y-2 text-[12.5px]">
          <li><a href={`${base}/privacy/`} class="no-underline text-ink-muted-on-dark hover:text-ink-on-dark">Privacy</a></li>
          <li><a href={`${base}/terms/`} class="no-underline text-ink-muted-on-dark hover:text-ink-on-dark">Terms</a></li>
          <li><a href={`${base}/accessibility/`} class="no-underline text-ink-muted-on-dark hover:text-ink-on-dark">Accessibility</a></li>
          <li><a href="https://brokercheck.finra.org/" target="_blank" rel="noopener noreferrer" class="no-underline text-ink-muted-on-dark hover:text-ink-on-dark">FINRA BrokerCheck</a></li>
          <li><a href="https://www.sec.gov/about/forms/formcrs.pdf" target="_blank" rel="noopener noreferrer" class="no-underline text-ink-muted-on-dark hover:text-ink-on-dark">Form CRS</a></li>
        </ul>
      </div>
    </div>
  </div>
</footer>
