---
// CCPA-friendly cookie consent banner — quiet, dismissible.
// Sets a localStorage flag on dismiss; no analytics scripts ship by default.
---

<aside
  id="cookie-banner"
  hidden
  aria-label="Cookie notice"
  class="fixed inset-x-3 bottom-3 z-50 md:inset-x-auto md:right-6 md:bottom-6 md:max-w-md card shadow-elevated"
>
  <p class="text-sm text-ink leading-relaxed">
    This site uses essential cookies to operate and anonymous analytics cookies to help us understand how visitors use it. You can decline non-essential cookies at any time. See our <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/privacy/`} class="text-brand-navy underline underline-offset-2">Privacy Policy</a>.
  </p>
  <div class="mt-4 flex flex-wrap gap-2 justify-end">
    <button
      id="cookie-decline"
      type="button"
      class="text-sm font-medium px-4 py-2 rounded border border-default text-ink hover:bg-surface-muted"
    >
      Decline
    </button>
    <button
      id="cookie-accept"
      type="button"
      class="text-sm font-medium px-4 py-2 rounded bg-brand-navy text-ink-on-dark hover:bg-brand-navy-hover"
    >
      Accept
    </button>
  </div>
</aside>

<script>
  const KEY = "hs:cookie-consent:v1";
  const banner = document.getElementById("cookie-banner") as HTMLElement | null;
  const accept = document.getElementById("cookie-accept");
  const decline = document.getElementById("cookie-decline");

  function hide() {
    if (banner) banner.hidden = true;
  }
  function show() {
    if (banner) banner.hidden = false;
  }

  try {
    const stored = localStorage.getItem(KEY);
    if (!stored) show();
  } catch {
    show();
  }

  accept?.addEventListener("click", () => {
    try {
      localStorage.setItem(KEY, "accepted");
    } catch {}
    hide();
  });

  decline?.addEventListener("click", () => {
    try {
      localStorage.setItem(KEY, "declined");
    } catch {}
    hide();
  });
</script>
