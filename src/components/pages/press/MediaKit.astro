---
import Eyebrow from "@components/Eyebrow.astro";
import Heading from "@components/Heading.astro";

const downloads = [
  {
    label: "Firm logo pack",
    description: "PDF, SVG, and PNG marks for editorial and print use",
    subject: "Media%20Kit%20Request%20-%20Logo%20Pack",
  },
  {
    label: "Firm boilerplate",
    description: "Approved one-paragraph and one-page descriptions of the firm",
    subject: "Media%20Kit%20Request%20-%20Boilerplate",
  },
  {
    label: "Principals’ bio sheet",
    description: "Long and short bios for Thomas J. Fanning, Sr. and partners",
    subject: "Media%20Kit%20Request%20-%20Bios",
  },
];
---

<section class="border-t border-rule pt-16 md:pt-20">
  <div class="grid gap-12 md:grid-cols-[1fr_1.2fr] md:gap-x-16">
    <div class="max-w-screen-prose">
      <Eyebrow>Press resources</Eyebrow>
      <Heading size="display-md" as="h2" class="mt-5 text-balance">
        A small media kit.
      </Heading>
      <p class="mt-6 prose-editorial text-[1.0625rem] leading-[1.65] text-ink-muted">
        Heritage Strategies maintains a quiet set of brand assets and approved biographies for press, conference, and publication use. Each is available on request from the firm.
      </p>
      <p class="mt-4 prose-editorial text-[1rem] leading-[1.65] text-ink-muted">
        We respond to journalists, conference organizers, and editorial researchers within two business days.
      </p>
    </div>

    <ul class="border-t border-rule">
      {downloads.map((item) => (
        <li class="border-b border-rule py-6 grid grid-cols-[1fr_auto] gap-x-6 items-center">
          <div>
            <p class="font-sans font-semibold text-[1rem] text-ink leading-tight">
              {item.label}
            </p>
            <p class="mt-1.5 text-[13px] leading-[1.5] text-ink-muted">
              {item.description}
            </p>
            <p class="mt-2 text-[12px] tracking-[0.04em] uppercase text-ink-muted">
              Available on request
            </p>
          </div>
          <a
            href={`mailto:press@heritagesllc.com?subject=${item.subject}`}
            class="inline-flex items-center justify-center gap-2 rounded border border-rule px-4 py-2 text-[13px] font-medium tracking-[0.01em] text-ink hover:border-rule hover:bg-surface-muted transition-colors duration-fast no-underline"
          >
            Request
            <svg
              aria-hidden="true"
              viewBox="0 0 12 12"
              class="h-[0.7em] w-[0.7em]"
              fill="none"
              stroke="currentColor"
              stroke-width="1.4"
            >
              <path d="M3.5 8.5 L8.5 3.5" stroke-linecap="round" />
              <path d="M4 3.5 H8.5 V8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
