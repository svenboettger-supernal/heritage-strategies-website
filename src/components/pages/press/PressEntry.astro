---
export interface Props {
  date: Date;
  publication: string;
  title: string;
  summary?: string;
  url?: string;
}

const { date, publication, title, summary, url } = Astro.props;

// Format date as e.g. "March 2002" — month + year, no day, since most are point-in-time
// appointments or memberships. Use a stable Intl format with en-US.
const dateLabel = new Intl.DateTimeFormat("en-US", {
  month: "long",
  year: "numeric",
}).format(date);

const isoDate = date.toISOString().slice(0, 10);
---

<article class="grid grid-cols-1 md:grid-cols-[10rem_1fr] gap-x-10 gap-y-3 py-10 first:pt-0 border-b border-rule last:border-b-0">
  <div class="md:pt-2">
    <time
      datetime={isoDate}
      data-figures="tabular"
      class="block text-[0.8125rem] font-medium tracking-[0.06em] text-ink-muted uppercase"
    >
      {dateLabel}
    </time>
  </div>

  <div class="max-w-screen-prose">
    <p class="eyebrow">{publication}</p>

    <h3 class="mt-3 font-display font-normal text-[1.6rem] leading-[1.2] tracking-[-0.005em] text-ink text-balance">
      {url ? (
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="no-underline text-ink hover:text-surface-navy transition-colors duration-fast"
        >
          {title}
          <svg
            aria-hidden="true"
            viewBox="0 0 12 12"
            class="inline-block ml-1 -translate-y-1 h-[0.7em] w-[0.7em]"
            fill="none"
            stroke="currentColor"
            stroke-width="1.4"
          >
            <path d="M3.5 8.5 L8.5 3.5" stroke-linecap="round" />
            <path d="M4 3.5 H8.5 V8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span class="sr-only">(opens in a new window)</span>
        </a>
      ) : (
        title
      )}
    </h3>

    {summary && (
      <p class="mt-4 prose-editorial text-[1.0625rem] leading-[1.65] text-ink-muted">
        {summary}
      </p>
    )}
  </div>
</article>
