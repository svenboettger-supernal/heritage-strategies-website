---
import Section from "@components/Section.astro";
import Heading from "@components/Heading.astro";
import Eyebrow from "@components/Eyebrow.astro";
import PlaceholderImage from "@components/PlaceholderImage.astro";

const cards = [
  {
    label: "Crossways Park Drive office",
    caption:
      "The firm's headquarters at 135 Crossways Park Drive, Woodbury, New York. Built for quiet work and unhurried conversation.",
  },
  {
    label: "Community partnership: St. Francis Hospital Foundation",
    caption:
      "Tom Sr. serves as Vice Chairman of the Foundation Board. Heritage team members are active across fundraising and program work.",
  },
  {
    label: "Continuing education at Fairfield University Dolan School of Business",
    caption:
      "Tom Sr. chairs the Dolan School of Business Advisory Council. The firm sends staff back to campus regularly for lectures and continuing education.",
  },
];
---

{/* placeholder: production photography to be supplied by Heritage per SOW §6.2 */}
<Section background="muted" padding="loose" width="default">
  <div class="max-w-screen-prose">
    <Eyebrow>Team life</Eyebrow>
    <Heading size="display-lg" class="mt-5 text-balance">
      Where the work happens, and where the firm shows up.
    </Heading>
    <p class="mt-6 prose-editorial text-[1.0625rem] leading-[1.6] text-ink-muted">
      Heritage is a quiet office in Woodbury and an active presence at the institutions the partners have spent careers supporting. Both matter to the people who choose to work here.
    </p>
  </div>

  <div class="mt-16 grid gap-8 md:grid-cols-3">
    {cards.map((card) => (
      <figure class="flex flex-col">
        <PlaceholderImage aspect="landscape" label={card.label} />
        <figcaption class="mt-5">
          <p class="font-display text-[1.25rem] leading-snug text-ink text-balance">
            {card.label}
          </p>
          <p class="mt-2 text-[14px] leading-relaxed text-ink-muted">
            {card.caption}
          </p>
        </figcaption>
      </figure>
    ))}
  </div>
</Section>
