---
import Container from "@components/Container.astro";
import Heading from "@components/Heading.astro";
import Eyebrow from "@components/Eyebrow.astro";
import Button from "@components/Button.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section class="relative bg-surface-dark text-ink-on-dark on-dark overflow-hidden" aria-label="Talk to Heritage">
  {/* quiet atmospheric tint */}
  <div
    aria-hidden="true"
    class="absolute inset-0 pointer-events-none"
    style="background:
      radial-gradient(70% 60% at 14% 22%, hsl(217 50% 22% / 0.55), transparent 65%),
      radial-gradient(80% 70% at 88% 78%, hsl(217 65% 9% / 0.55), transparent 72%);"
  ></div>

  {/* hairline streak */}
  <span
    aria-hidden="true"
    class="absolute left-[8%] right-[18%] top-[58%] h-px -rotate-[1.8deg] origin-left"
    style="background: linear-gradient(90deg, hsl(0 0% 100% / 0), hsl(0 0% 100% / 0.42) 30%, hsl(0 0% 100% / 0.42) 70%, hsl(0 0% 100% / 0));"
  ></span>

  <Container width="default" class="relative py-24 md:py-32">
    <div class="max-w-screen-prose">
      <Eyebrow class="text-ink-muted-on-dark">A direct conversation</Eyebrow>
      <Heading size="display-lg" as="h2" class="mt-5 text-ink-on-dark text-balance">
        Reach out to a member of the team you would want to work with.
      </Heading>
      <p class="mt-6 font-editorial text-[1.125rem] leading-[1.6] text-ink-muted-on-dark max-w-xl">
        If you are weighing a move, the firm would rather start with a low-pressure conversation than a formal application. Send a note and we will route it to the partner whose desk fits your background.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-4">
        <Button href={`${base}/contact/`} variant="on-dark" size="lg">
          Contact Heritage
        </Button>
        <a
          href="mailto:careers@heritagesllc.com?subject=Introduction%20%E2%80%93%20Heritage%20Strategies"
          class="text-[14px] font-medium tracking-[0.01em] text-ink-on-dark/85 hover:text-ink-on-dark no-underline border-b border-on-dark hover:border-ink-on-dark pb-1"
        >
          Email careers@heritagesllc.com
        </a>
      </div>
    </div>
  </Container>
</section>
