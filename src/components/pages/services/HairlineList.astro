---
export interface Props {
  items: string[];
  onDark?: boolean;
  class?: string;
}

const { items, onDark = false, class: className = "" } = Astro.props;
---

<ul
  class:list={[
    "divide-y border-t border-b",
    onDark ? "divide-[hsl(var(--rule-dark))] border-rule-dark" : "divide-[hsl(var(--rule))] border-rule",
    className,
  ]}
>
  {items.map((item) => (
    <li
      class:list={[
        "py-4 text-[15px] leading-relaxed",
        onDark ? "text-ink-on-dark" : "text-ink",
      ]}
    >
      {item}
    </li>
  ))}
</ul>
