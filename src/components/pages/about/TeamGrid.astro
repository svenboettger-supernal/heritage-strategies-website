---
import { getCollection } from "astro:content";
import Section from "@components/Section.astro";
import Eyebrow from "@components/Eyebrow.astro";
import Heading from "@components/Heading.astro";
import PlaceholderImage from "@components/PlaceholderImage.astro";

const team = (await getCollection("team"))
  .sort((a, b) => a.data.order - b.data.order);
---

<Section background="page" padding="loose" width="default" id="team">
  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-14 md:mb-20">
    <div class="max-w-xl">
      <Eyebrow>The full team</Eyebrow>
      <Heading size="display-md" class="mt-4 text-balance">
        Eighteen people, one practice.
      </Heading>
    </div>
    <p class="text-[15px] leading-relaxed text-ink-muted max-w-sm">
      Every name here works on every engagement, in some form. Insurance, case design, underwriting, policy service, analysis, operations.
    </p>
  </div>

  <ul class="grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
    {team.map((p) => (
      <li id={p.slug} class="flex flex-col scroll-mt-24">
        <PlaceholderImage
          aspect="square"
          label={p.data.name}
          class="mb-5"
        />

        <h3 class="font-display text-[1.35rem] leading-[1.2] tracking-[-0.005em] text-ink text-balance">
          {p.data.name}
        </h3>

        <p class="mt-1.5 text-[13px] font-medium tracking-[0.01em] text-ink-muted">
          {p.data.role}
        </p>

        {(p.data.credentials && p.data.credentials.length > 0) && (
          <p class="mt-3 text-[11.5px] tracking-[0.06em] text-ink-muted">
            {p.data.credentials.map((c, i) => (
              <>
                <span class="font-mono">{c}</span>
                {i < (p.data.credentials!.length - 1) && <span class="opacity-50 mx-1.5">·</span>}
              </>
            ))}
          </p>
        )}

        {p.data.location && (
          <p class="mt-2 text-[12px] tracking-[0.02em] text-ink-placeholder">
            {p.data.location}
          </p>
        )}
      </li>
    ))}
  </ul>
</Section>
