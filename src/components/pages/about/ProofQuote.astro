---
import { getEntry } from "astro:content";
import Section from "@components/Section.astro";
import Eyebrow from "@components/Eyebrow.astro";
import Quote from "@components/Quote.astro";

const testimonial = await getEntry("testimonials", "family-office-principal");
const data = testimonial?.data;
---

<Section background="muted" padding="loose" width="default">
  <div class="mx-auto max-w-screen-prose text-center">
    <Eyebrow class="mx-auto">In a client's words</Eyebrow>

    <div class="mt-10 flex justify-center">
      <Quote
        attribution={data?.attribution}
        anonymized={data?.anonymized ?? true}
      >
        {data?.quote}
      </Quote>
    </div>
  </div>
</Section>
