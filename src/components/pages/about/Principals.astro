---
import { getCollection } from "astro:content";
import Section from "@components/Section.astro";
import Eyebrow from "@components/Eyebrow.astro";
import Heading from "@components/Heading.astro";
import PlaceholderImage from "@components/PlaceholderImage.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const principals = (await getCollection("team", ({ data }) => data.isPrincipal))
  .sort((a, b) => a.data.order - b.data.order);

// Pull the first paragraph of each principal's body for the excerpt.
function firstParagraph(body: string): string {
  const trimmed = body.trim();
  const idx = trimmed.indexOf("\n\n");
  return (idx === -1 ? trimmed : trimmed.slice(0, idx)).trim();
}
---

<Section background="muted" padding="loose" width="default" id="principals">
  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-14 md:mb-20">
    <div class="max-w-xl">
      <Eyebrow>Founders and principals</Eyebrow>
      <Heading size="display-md" class="mt-4 text-balance">
        The senior people who do the work.
      </Heading>
    </div>
    <p class="text-[15px] leading-relaxed text-ink-muted max-w-sm">
      Heritage is a small firm. The principals below sit on every engagement, alongside the family's own advisors.
    </p>
  </div>

  <div class="grid gap-10 md:grid-cols-2 xl:grid-cols-4 md:gap-8 xl:gap-10">
    {principals.map((p) => (
      <article class="flex flex-col">
        <PlaceholderImage
          aspect="portrait"
          label={p.data.name}
          class="mb-7"
        />

        <h3 class="font-display text-[1.65rem] leading-[1.15] tracking-[-0.005em] text-ink text-balance">
          {p.data.name}
        </h3>

        <p class="eyebrow mt-3">{p.data.role}</p>

        <p class="mt-5 text-[15.5px] leading-[1.65] font-editorial text-ink">
          {firstParagraph(p.body)}
        </p>

        {(p.data.credentials && p.data.credentials.length > 0) && (
          <p class="mt-5 text-[12px] tracking-[0.05em] text-ink-muted">
            {p.data.credentials.map((c, i) => (
              <>
                <span class="font-mono">{c}</span>
                {i < (p.data.credentials!.length - 1) && <span class="opacity-50 mx-1.5">·</span>}
              </>
            ))}
          </p>
        )}

        <a
          href={`${base}/about/#${p.slug}`}
          class="mt-7 inline-flex items-center gap-2 text-[13px] font-medium tracking-[0.02em] text-brand-navy hover:text-brand-navy-hover no-underline border-b border-default hover:border-strong pb-1 self-start"
        >
          Read full bio
          <span aria-hidden="true">→</span>
        </a>
      </article>
    ))}
  </div>
</Section>
