---
/**
 * Home hero — direct port of the heritage-brand demo hero, adapted to the
 * Heritage Strategies firm context. Dark radial-gradient ground, continuous-wave
 * atmosphere, left-aligned content inside an 880px max-width column.
 */
import ContinuousWave from "@components/ContinuousWave.astro";
import Button from "@components/Button.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section
  class="hero relative isolate overflow-hidden text-white on-dark"
  style="background: radial-gradient(ellipse 80% 60% at 50% 38%, #1B3358 0%, #0F1E36 55%, #08121F 100%); padding: clamp(112px, 14vw, 184px) 0;"
  aria-labelledby="hero-title"
>
  <ContinuousWave tone="on-dark" />

  <div class="relative z-10 w-full mx-auto px-6 sm:px-10 lg:px-14" style="max-width: 1180px;">
    <div style="max-width: 880px;">
      <p
        class="font-sans font-medium uppercase text-ink-muted-on-dark"
        style="font-size: 12px; letter-spacing: 0.18em; margin: 0 0 28px 0;"
      >
        Heritage Strategies LLC · since 2009
      </p>

      <h1
        id="hero-title"
        class="font-display font-normal text-white text-balance"
        style='font-variation-settings: "opsz" 60; font-size: clamp(48px, 7vw, 80px); line-height: 1.04; letter-spacing: -0.015em; margin: 0 0 32px 0;'
      >
        Your family's wealth, intact and intentional, across generations you won't live to see.
      </h1>

      <p
        class="font-sans text-white text-pretty"
        style="font-size: clamp(17px, 1.6vw, 19px); line-height: 1.65; opacity: 0.85; max-width: 620px; margin: 0 0 48px 0;"
      >
        Heritage is an estate-planning multi-family office for ultra-high-net-worth families navigating a generational handoff, a liquidity event, or the long, careful work of preserving a multi-generational balance sheet. We work alongside your attorneys, trustees, and accountants to build a single, living plan, owned and dated, that holds up the day it is needed.
      </p>

      <div class="flex flex-wrap gap-3">
        <Button
          href={`${base}/contact/`}
          variant="on-dark"
          ariaLabel="Request a confidential conversation"
        >
          Request a confidential conversation
        </Button>
        <Button
          href={`${base}/services/methodology/`}
          variant="on-dark-secondary"
        >
          The Heritage Book methodology
        </Button>
      </div>
    </div>
  </div>
</section>
