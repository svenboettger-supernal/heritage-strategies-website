---
import WaxSeal from "@components/WaxSeal.astro";
import Button from "@components/Button.astro";

export interface Props {
  pathname?: string;
}
const { pathname = "/" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const nav = [
  { label: "Services", href: `${base}/services/` },
  { label: "About", href: `${base}/about/` },
  { label: "Press", href: `${base}/press/` },
  { label: "Resources", href: `${base}/resources/` },
  { label: "Careers", href: `${base}/careers/` },
];

const isActive = (href: string) => {
  const trimmed = href.replace(base, "").replace(/\/$/, "");
  const current = pathname.replace(/\/$/, "");
  return trimmed && current.startsWith(trimmed);
};
---

<header
  class="sticky top-0 z-40 bg-surface-page/85 backdrop-blur supports-[backdrop-filter]:bg-surface-page/70 border-b border-default"
>
  <div class="mx-auto max-w-screen-wide px-6 sm:px-8 lg:px-12 py-4 md:py-5 flex items-center justify-between gap-6">
    <WaxSeal href={`${base}/`} size={44} ariaLabel="Heritage Strategies LLC, home" />

    <nav aria-label="Primary" class="hidden lg:flex items-center gap-7">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "text-[14px] font-medium tracking-[0.01em] no-underline transition-colors duration-fast",
            isActive(item.href)
              ? "text-brand-navy"
              : "text-ink-muted hover:text-ink",
          ]}
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <Button href={`${base}/contact/`} variant="primary" size="sm" class="hidden md:inline-flex">
        Request a Conversation
      </Button>
      <button
        id="nav-toggle"
        type="button"
        aria-controls="nav-mobile"
        aria-expanded="false"
        class="lg:hidden p-2 -m-2 text-ink"
        aria-label="Open navigation"
      >
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
          <line x1="3" y1="6" x2="19" y2="6" />
          <line x1="3" y1="11" x2="19" y2="11" />
          <line x1="3" y1="16" x2="19" y2="16" />
        </svg>
      </button>
    </div>
  </div>

  <div id="nav-mobile" hidden class="lg:hidden border-t border-default bg-surface-card">
    <nav aria-label="Primary mobile" class="mx-auto max-w-screen-wide px-6 sm:px-8 py-4 flex flex-col gap-1">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "py-3 text-[15px] no-underline border-b border-default last:border-b-0",
            isActive(item.href) ? "text-brand-navy font-medium" : "text-ink",
          ]}
        >
          {item.label}
        </a>
      ))}
      <a
        href={`${base}/contact/`}
        class="mt-3 inline-flex items-center justify-center bg-brand-navy text-ink-on-dark rounded px-5 py-3 font-medium text-sm"
      >
        Request a Conversation
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const mobile = document.getElementById("nav-mobile");
  toggle?.addEventListener("click", () => {
    const open = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!open));
    if (mobile) mobile.hidden = open;
  });
</script>
