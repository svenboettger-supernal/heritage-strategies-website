---
export interface Props {
  attribution?: string;
  role?: string;
  anonymized?: boolean;
  class?: string;
}
const { attribution, role, anonymized = false, class: className = "" } = Astro.props;
---

<figure class:list={["max-w-screen-prose", className]}>
  <span aria-hidden="true" class="block font-display text-brand-copper text-display-md leading-none mb-2">"</span>
  <blockquote class="font-display text-[1.6rem] md:text-[2rem] leading-[1.3] text-ink text-balance">
    <slot />
  </blockquote>
  {(attribution || anonymized) && (
    <figcaption class="mt-6 text-[13px] tracking-[0.05em] uppercase text-ink-muted">
      {anonymized ? "Family Office Principal, anonymized at client request" : attribution}
      {role && !anonymized && <span class="text-ink-placeholder normal-case tracking-normal"> · {role}</span>}
    </figcaption>
  )}
</figure>
