---
export interface Props {
  /** Treatment color. "auto" inherits from on-dark context. */
  color?: "auto" | "light" | "dark";
  /** Pixel width as a percentage. */
  widthPct?: number;
  /** Disable the slant. */
  straight?: boolean;
  class?: string;
}

const { color = "auto", widthPct = 60, straight = false, class: className = "" } = Astro.props;
---

<span
  aria-hidden="true"
  class:list={[
    "block h-px",
    !straight && "-rotate-[1deg] origin-left",
    className,
  ]}
  style={`width: ${widthPct}%; background-color: ${color === "light" ? "hsl(0 0% 100% / 0.35)" : "hsl(var(--rule))"};`}
></span>
